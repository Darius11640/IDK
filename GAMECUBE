// Get all property titles
let titles = document.querySelectorAll('.text-title');

// Show only the first 10 (or less if there are fewer)
let count = 10;
if (titles.length < 10) count = titles.length;

console.log('Properties:');
for (let i = 0; i < count; i = i + 1) {
  console.log(i + 1 + '. ' + titles[i].textContent.trim());
}